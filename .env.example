NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro
# Imágenes: Pollinations.ai, gratis y sin cuenta — no necesita clave.
# POLLINATIONS_MODEL=flux
# Voz narrada: ElevenLabs (cuenta gratis con límite mensual de caracteres).
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# Ruta al binario de ffmpeg (usa ffmpeg-full para que funcionen los subtítulos incrustados).
FFMPEG_PATH=/opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
FFPROBE_PATH=/opt/homebrew/opt/ffmpeg-full/bin/ffprobe
PORT=3001
